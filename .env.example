# GEO Measurement Platform — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real secrets. Never log these values.

# AI engine API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Supabase (Postgres) storage
SUPABASE_URL=
SUPABASE_KEY=

# Optional: SearchApi.io key to capture Google AI Overviews (no official Google API)
SEARCHAPI_API_KEY=

# Isolation & determinism controls (docs/isolation-determinism-plan.md)
# Best-effort reproducibility seed sent to providers that accept one (OpenAI, Gemini).
ENGINE_SEED=42
# Optional: append every outgoing engine request body (secrets scrubbed) as JSON
# lines to this file, so any run is reconstructable. Unset = debug logging only.
PAYLOAD_LOG_PATH=
