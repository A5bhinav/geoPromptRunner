# GEO Measurement Platform — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real secrets. Never log these values.

# AI engine API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Supabase (Postgres) storage
SUPABASE_URL=
SUPABASE_KEY=

# Optional: SerpApi key to capture Google AI Overviews (no official Google API)
SERPAPI_API_KEY=
