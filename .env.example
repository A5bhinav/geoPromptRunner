# GEO Measurement Platform — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Never commit real secrets. Never log these values.

# AI engine API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=

# Supabase (Postgres) storage
SUPABASE_URL=
SUPABASE_KEY=

# Optional: SearchApi.io key to capture Google AI Overviews (no official Google API)
SEARCHAPI_API_KEY=

# --- API security (FastAPI layer) ---
# Shared key required on every API endpoint (sent as the X-API-Key header).
# UNSET = the API is OPEN (local dev only) — SET THIS before exposing the API.
# The Next.js frontend must send the same value as NEXT_PUBLIC_GEO_API_KEY
# (in web/.env.local). Note: NEXT_PUBLIC_* ships to the browser, so this gates
# anonymous access, not per-user access — keep the frontend itself protected.
GEO_API_KEY=
# Allowed browser origins for CORS (comma-separated). Default: http://localhost:3000.
# Set to your deployed frontend URL(s) in production — never "*".
GEO_CORS_ORIGINS=http://localhost:3000
# Abuse / cost ceilings on a single uploaded audit (enforced before any LLM call).
MAX_UPLOAD_BYTES=5242880
MAX_QUERIES=200
MAX_ENGINES=8
MAX_RUNS_PER_QUERY=5
# Spend guard (rough estimated USD, engines + judge) — the hard cap on burning
# credits. A single audit over MAX_AUDIT_COST_USD is refused (402); once accepted
# audits this process would exceed MAX_TOTAL_SPEND_USD, further runs are refused.
# Cumulative total resets on API restart. Set either to 0 to disable that check.
MAX_AUDIT_COST_USD=25
MAX_TOTAL_SPEND_USD=200

# Isolation & determinism controls (docs/isolation-determinism-plan.md)
# Best-effort reproducibility seed sent to providers that accept one (OpenAI, Gemini).
ENGINE_SEED=42
# Optional: append every outgoing engine request body (secrets scrubbed) as JSON
# lines to this file, so any run is reconstructable. Unset = debug logging only.
PAYLOAD_LOG_PATH=
